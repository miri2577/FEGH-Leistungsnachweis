# Kopie als deploy/.env.prod anlegen (NICHT ins Git; chmod 600, chown deploy).
# Secret-Key erzeugen: python -c "import secrets;print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=bitte-frischen-64-zeichen-zufallswert-einsetzen
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=nachweis.deine-domain.de
DJANGO_CSRF_TRUSTED_ORIGINS=https://nachweis.deine-domain.de
# 2FA für alle verpflichtend
DJANGO_OTP_REQUIRED=1
# HSTS beim ersten Rollout kurz testen (300), dann auf 31536000 (1 Jahr) hochsetzen
DJANGO_HSTS_SECONDS=300

# PostgreSQL
POSTGRES_DB=fegh
POSTGRES_USER=fegh
POSTGRES_PASSWORD=langes-zufallspasswort-einsetzen
DATABASE_URL=postgres://fegh:langes-zufallspasswort-einsetzen@db:5432/fegh

# --- Backup-Cron (deploy/backup.sh) – in der Cron-Umgebung des deploy-Users setzen ---
# Offsite-Spiegel (3-2-1-Regel): rclone-Remote, sonst liegt das Backup NUR lokal.
# RCLONE_REMOTE=hidrive:fegh-backups/
# Dead-Man's-Switch: Ping-URL (z. B. healthchecks.io, EU) – Alarm, wenn er ausbleibt.
# HEALTHCHECK_URL=https://hc-ping.com/DEINE-UUID
# age-Empfänger (öffentliche Keys). Mehrere = Bus-Faktor (zweiter Key beim Träger);
# alternativ deploy/age-recipients.txt (eine Zeile je Key).
# AGE_RECIPIENTS="age1DEIN_PUBLIC_KEY age1TRAEGER_PUBLIC_KEY"
